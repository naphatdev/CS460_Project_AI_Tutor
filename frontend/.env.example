# ===== Frontend Environment Variables =====
# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าตามต้องการ
#   cp .env.example .env

# Backend API base URL — override ถ้า backend รันที่อื่น (default = http://localhost:8000)
VITE_API_BASE_URL=http://localhost:8000

# ตั้งเป็น "true" เพื่อใช้ mock data แทนเรียก backend จริง
# มีประโยชน์ระหว่างที่ backend ยังไม่เสร็จ หรือเวลาทำ UI โดยไม่ต้องรัน backend
VITE_USE_MOCK=false
